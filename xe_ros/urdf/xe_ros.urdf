    <inertial>
      <origin
        xyz="-1.1796E-16 0.0023818 -0.026941"
        rpy="0 0 0" />
      <mass
        value="0.05668" />
      <inertia
        ixx="1.1271E-05"
        ixy="-4.9371E-20"
        ixz="1.4804E-20"
        iyy="1.8455E-05"
        iyz="1.4295E-07"
        izz="1.5462E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="-1.5707963267949 0 -1.5707963267949" />
      <geometry>
        <mesh
          filename="package://xe_ros/meshes/camera.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
  </link>
  <joint
    name="cam_mount"
    type="fixed">
    <origin
      xyz="0.134857985873818 0 0.0225"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="camera" />
    <axis
      xyz="0 0 0" />
  </joint>
  <link
    name="lidar">
    <inertial>
      <origin
        xyz="8.3267E-17 3.4694E-17 -0.010546"
        rpy="0 0 0" />
      <mass
        value="0.03774" />
      <inertia
        ixx="6.7746E-06"
        ixy="7.918E-35"
        ixz="-2.2212E-20"
        iyy="6.7746E-06"
        iyz="-1.1345E-20"
