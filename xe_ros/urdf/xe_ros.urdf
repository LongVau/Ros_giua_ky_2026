  <gazebo reference="front_left_wheel">
    <mu1>1.9</mu1>
    <mu2>0.5</mu2>
    <kp>100000.0</kp> <kd>100.0</kd>  <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <mu1>1.9</mu1>
    <mu2>0.5</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rear_left_wheel">
    <mu1>3.0</mu1>
    <mu2>3.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <mu1>3.0</mu1>
    <mu2>3.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
